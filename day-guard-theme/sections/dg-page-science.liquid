<!-- ════════════════════════════
     HERO
════════════════════════════ -->
<section class="sci-hero">
  <div class="sci-hero-left">
    <h1 class="sci-hero-h1">science backed.<br>protection hacked.</h1>
    <p class="sci-hero-sub">Every ingredient in day–guard is clinically backed, transparently dosed, and formulated to work—not just look good on a label.</p>
    <div class="sci-stats-row">
      <div class="sci-stat">
        <span class="sci-stat-num">60+</span>
        <span class="sci-stat-label">years of pharma<br>expertise</span>
      </div>
      <div class="sci-stat-divider"></div>
      <div class="sci-stat">
        <span class="sci-stat-num">167</span>
        <span class="sci-stat-label">clinical studies<br>backing ingredients</span>
      </div>
      <div class="sci-stat-divider"></div>
      <div class="sci-stat">
        <span class="sci-stat-num">GMP</span>
        <span class="sci-stat-label">certified<br>manufacturing</span>
      </div>
    </div>
    <a href="{{ routes.all_products_collection_url }}" class="sci-hero-btn">shop now →</a>
  </div>
  <div class="sci-hero-right">
    <img src="{{ 'science-hero.jpg' | asset_url }}" alt="day–guard product" class="sci-hero-img">
  </div>
</section>

<!-- Science pillars -->
<section class="science-section science-section--pdp" id="ingredients">
  <div class="science-inner">
    <div class="science-header fade-up">
      <span class="science-tag">WHAT'S INSIDE</span>
      <h2 class="science-heading">the science</h2>
      <p class="science-sub">Every ingredient in day—guard is clinically backed, transparently dosed, and formulated to protect your body the morning after.</p>
    </div>

    <div class="pillar-grid">
      <div class="pillar-card fade-up" data-pillar="liver">
        <img class="pillar-bg" src="{{ 'Liver Support.png' | asset_url }}" alt="Liver Support">
        <div class="pillar-gradient" style="background:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 60%);"></div>
        <span class="pillar-label">Liver Support</span>
      </div>
      <div class="pillar-card fade-up" data-pillar="gut" style="transition-delay:.08s">
        <img class="pillar-bg" src="{{ 'Gut Support.png' | asset_url }}" alt="Gut Support">
        <div class="pillar-gradient" style="background:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 60%);"></div>
        <span class="pillar-label">Gut Support</span>
      </div>
      <div class="pillar-card fade-up" data-pillar="vitamins" style="transition-delay:.16s">
        <img class="pillar-bg" src="{{ 'Vitamin Replenishment.png' | asset_url }}" alt="Vitamin Replenishment">
        <div class="pillar-gradient" style="background:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 60%);"></div>
        <span class="pillar-label">Vitamin Replenishment</span>
      </div>
      <div class="pillar-card fade-up" data-pillar="hydration" style="transition-delay:.24s">
        <img class="pillar-bg" src="{{ 'Hydration.png' | asset_url }}" alt="Hydration">
        <div class="pillar-gradient" style="background:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 60%);"></div>
        <span class="pillar-label">Hydration</span>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════
     BROWN UNIVERSITY CARD
════════════════════════════ -->
<section class="sci-green-section">
  <div class="sci-green-card sci-card-img-right" id="doctor">
    <div class="sci-green-text">
      <p class="sci-green-eyebrow">Brown University</p>
      <h2 class="sci-green-h2">built with doctors,<br>backed by science.</h2>
      <blockquote class="sci-green-quote">"The formulation behind day–guard is exactly what I'd recommend to any patient looking to protect their liver and gut while socializing."</blockquote>
      <div class="sci-green-author">
        <div class="sci-green-avatar">SO</div>
        <div>
          <p class="sci-green-author-name">Dr. Steven Oh, MD</p>
          <p class="sci-green-author-title">Medical Advisor · Brown University Alum</p>
        </div>
      </div>
      <a href="{{ routes.all_products_collection_url }}" class="sci-green-pill-link">Read the study →</a>
    </div>
    <div class="sci-green-photo">
      <img src="{{ 'science-doctor.jpg' | asset_url }}" alt="Dr. Steven Oh, MD">
    </div>
  </div>
</section>

<!-- ════════════════════════════
     MADE IN KOREA CARD
════════════════════════════ -->
<section class="sci-green-section sci-green-section--alt">
  <div class="sci-green-card sci-card-img-left" id="manufacturer">
    <div class="sci-green-photo">
      <img src="{{ 'science-korea.jpg' | asset_url }}" alt="Korean pharmaceutical facility">
    </div>
    <div class="sci-green-text">
      <p class="sci-green-eyebrow">made in korea</p>
      <h2 class="sci-green-h2 sci-green-h2--lg">60+ years of pharmaceutical expertise.</h2>
      <p class="sci-green-body">day–guard is manufactured by a Korean pharmaceutical company founded in 1963. In Korea, where jelly stick supplements are part of everyday wellness culture, our partner has spent decades perfecting the format — precise dosing, superior bioavailability, and a format you'll actually use.</p>
      <div class="sci-badges-grid">
        <div class="sci-badge"><span class="sci-badge-dot"></span>Founded 1963</div>
        <div class="sci-badge"><span class="sci-badge-dot"></span>GMP Certified</div>
        <div class="sci-badge"><span class="sci-badge-dot"></span>FDA Registered</div>
        <div class="sci-badge"><span class="sci-badge-dot"></span>167+ Studies</div>
      </div>
    </div>
  </div>
</section>

<!-- Press section -->
<section class="press-section" id="press">
  <img class="press-bg"
       src="https://www.figma.com/api/mcp/asset/6623c733-4e3c-4dd3-ae01-cc4200402162"
       alt="" aria-hidden="true">
  <div class="press-inner">
    <p class="press-label fade-up">day–guard in the press</p>
    <blockquote class="press-quote fade-up" id="press-quote">&ldquo;day–guard brings Korean wellness culture to American consumers through a reimagined approach to social drinking.&rdquo;</blockquote>
    <div class="press-logos fade-up">
      <button class="press-logo-btn active" data-publication="Forbes"
              data-quote="&ldquo;day&ndash;guard brings Korean wellness culture to American consumers through a reimagined approach to social drinking.&rdquo;">
        <img class="press-logo" src="{{ 'Forbes_logo.svg' | asset_url }}" alt="Forbes">
      </button>
      <button class="press-logo-btn" data-publication="SFGate"
              data-quote="&ldquo;day&ndash;guard turns pre-drinking support into an easy, on-the-go ritual instead of another pill or powder.&rdquo;">
        <img class="press-logo" src="{{ 'Logo_of_SFGate.svg' | asset_url }}" alt="SF Gate">
      </button>
      <button class="press-logo-btn" data-publication="The Korea Herald"
              data-quote="&ldquo;day&ndash;guard brings Korea&rsquo;s preventive drinking ritual to the U.S. in a format that feels modern, effective, and easy to use.&rdquo;">
        <img class="press-logo" src="{{ 'The_Korea_Herald__idup90auts_1_1.svg' | asset_url }}" alt="The Korea Herald">
      </button>
      <button class="press-logo-btn" data-publication="The Boston Globe"
              data-quote="&ldquo;day&ndash;guard offers more than a hydration fix, pairing convenience with targeted liver support in a portable jelly stick.&rdquo;">
        <img class="press-logo" src="{{ 'The_Boston_Globe (1).svg' | asset_url }}" alt="The Boston Globe">
      </button>
    </div>
  </div>
</section>

{% stylesheet %}
/* ── Science Page ── */
:root {
  --sci-green: #214c3e;
  --sci-beige: #f4f1ec;
  --sci-orange: #fb9918;
  --sci-black: #1d1d1b;
  --sci-soft-green: #9aaca0;
}

/* Hero */
.sci-hero {
  display: grid;
  grid-template-columns: 1fr 500px;
  gap: 60px;
  max-width: 1302px;
  margin: 0 auto;
  padding: 80px 60px 90px;
  align-items: center;
  background: var(--sci-beige);
}
.sci-hero-left {
  display: flex;
  flex-direction: column;
  gap: 28px;
}
.sci-hero-h1 {
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 72px;
  font-weight: 700;
  letter-spacing: -2.88px;
  line-height: 1.0;
  color: #1e3a2a;
  margin: 0;
}
.sci-hero-sub {
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 17px;
  color: #555;
  line-height: 1.6;
  letter-spacing: -0.2px;
  max-width: 480px;
  margin: 0;
}
.sci-stats-row {
  display: flex;
  align-items: center;
  gap: 24px;
}
.sci-stat {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.sci-stat-num {
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--sci-green);
  letter-spacing: -1px;
  line-height: 1;
}
.sci-stat-label {
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 12px;
  color: #666;
  line-height: 1.4;
  letter-spacing: -0.1px;
}
.sci-stat-divider {
  width: 1px;
  height: 40px;
  background: rgba(0,0,0,0.15);
  flex-shrink: 0;
}
.sci-hero-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 253px;
  height: 58px;
  background: var(--sci-orange);
  color: #fff;
  border-radius: 5px;
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 16px;
  font-weight: 600;
  text-decoration: none;
  letter-spacing: -0.3px;
  transition: background 0.2s;
}
.sci-hero-btn:hover { background: #e8860f; }
.sci-hero-right {
  width: 500px;
  aspect-ratio: 1/1;
  border-radius: 30px;
  overflow: hidden;
  background: #e8e5e0;
}
.sci-hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}


/* Green cards */
.sci-green-section {
  background: var(--sci-green);
  padding: 60px;
}
.sci-green-section--alt {
  background: #1a3d31;
}
.sci-green-card {
  max-width: 1182px;
  margin: 0 auto;
  display: grid;
  gap: 60px;
  align-items: center;
  border-radius: 35px;
  overflow: hidden;
  background: var(--sci-green);
}
.sci-card-img-right {
  grid-template-columns: 1fr 480px;
}
.sci-card-img-left {
  grid-template-columns: 480px 1fr;
}
.sci-green-section--alt .sci-green-card {
  background: #1a3d31;
}
.sci-green-text {
  padding: 60px 0 60px 60px;
  display: flex;
  flex-direction: column;
  gap: 22px;
}
.sci-card-img-left .sci-green-text {
  padding: 60px 60px 60px 0;
}
.sci-green-eyebrow {
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--sci-orange);
  margin: 0;
}
.sci-green-h2 {
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 47px;
  font-weight: 700;
  letter-spacing: -1.88px;
  line-height: 1.0;
  color: #fff;
  margin: 0;
}
.sci-green-h2--lg {
  font-size: 51px;
  letter-spacing: -2px;
}
.sci-green-quote {
  font-family: 'Hedvig Letters Serif', Georgia, serif;
  font-size: 19px;
  font-style: italic;
  color: rgba(255,255,255,0.82);
  line-height: 1.55;
  border-left: 3px solid var(--sci-soft-green);
  padding-left: 18px;
  margin: 0;
}
.sci-green-author {
  display: flex;
  align-items: center;
  gap: 14px;
}
.sci-green-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--sci-soft-green);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.sci-green-author-name {
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 15px;
  font-weight: 600;
  color: #fff;
  margin: 0 0 2px;
}
.sci-green-author-title {
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 12px;
  color: rgba(255,255,255,0.6);
  margin: 0;
}
.sci-green-pill-link {
  display: inline-flex;
  align-items: center;
  height: 38px;
  padding: 0 20px;
  border: 1.5px solid rgba(255,255,255,0.45);
  border-radius: 999px;
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: #fff;
  text-decoration: none;
  width: fit-content;
  transition: border-color 0.2s, background 0.2s;
}
.sci-green-pill-link:hover {
  border-color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.08);
}
.sci-green-body {
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 16px;
  color: rgba(255,255,255,0.78);
  line-height: 1.65;
  letter-spacing: -0.2px;
  margin: 0;
}
.sci-badges-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px 24px;
}
.sci-badge {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: rgba(255,255,255,0.85);
  letter-spacing: -0.2px;
}
.sci-badge-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--sci-orange);
  flex-shrink: 0;
}
.sci-green-photo {
  height: 100%;
  min-height: 420px;
}
.sci-green-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}


/* Responsive */
@media (max-width: 1100px) {
  .sci-hero { grid-template-columns: 1fr; padding: 60px 40px 80px; }
  .sci-hero-right { width: 100%; max-width: 500px; }
  .sci-ing-grid { grid-template-columns: repeat(2, 1fr); }
  .sci-ing-heading { font-size: 52px; letter-spacing: -2px; }
  .sci-card-img-right,
  .sci-card-img-left { grid-template-columns: 1fr; }
  .sci-green-photo { min-height: 300px; max-height: 340px; }
  .sci-card-img-left .sci-green-photo { order: -1; }
  .sci-green-text { padding: 40px 40px 0; }
  .sci-card-img-left .sci-green-text { padding: 0 40px 40px; }
  .sci-green-section { padding: 40px 24px; }
}
@media (max-width: 768px) {
  .sci-hero-h1 { font-size: 44px; letter-spacing: -1.5px; }
  .sci-hero { padding: 40px 20px 60px; gap: 36px; }
  .sci-ingredients { padding: 0 20px 60px; }
  .sci-ing-heading { font-size: 38px; letter-spacing: -1.5px; }
  .sci-ing-grid { grid-template-columns: 1fr; }
  .sci-ing-card { height: 380px; }
  .sci-stats-row { flex-wrap: wrap; gap: 16px; }
  .sci-green-h2 { font-size: 34px; letter-spacing: -1.2px; }
  .sci-green-h2--lg { font-size: 36px; }
  .sci-press-quote { font-size: 26px; letter-spacing: -0.8px; }
  .sci-press-label { font-size: 22px; }
  .sci-press-logos { gap: 32px; }
}
{% endstylesheet %}


