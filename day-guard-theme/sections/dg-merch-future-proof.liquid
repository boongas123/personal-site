<section class="merch-pdp">

  <!-- Gallery -->
  <div class="mpdp-gallery">
    <div class="mpdp-gallery-main">
      <img src="{{ 'merch-1Y0A0842.jpg' | asset_url }}" alt="day–guard tee future proof" id="fp-main-img" class="mpdp-main-img">
    </div>
    <div class="mpdp-thumbs">
      <div class="mpdp-thumb active" onclick="mpdpSwap('fp-main-img', this, '{{ 'merch-1Y0A0842.jpg' | asset_url }}')">
        <img src="{{ 'merch-1Y0A0842.jpg' | asset_url }}" alt="">
      </div>
      <div class="mpdp-thumb" onclick="mpdpSwap('fp-main-img', this, '{{ 'merch-1Y0A0831.jpg' | asset_url }}')">
        <img src="{{ 'merch-1Y0A0831.jpg' | asset_url }}" alt="">
      </div>
      <div class="mpdp-thumb" onclick="mpdpSwap('fp-main-img', this, '{{ 'merch-1Y0A0868.jpg' | asset_url }}')">
        <img src="{{ 'merch-1Y0A0868.jpg' | asset_url }}" alt="">
      </div>
      <div class="mpdp-thumb" onclick="mpdpSwap('fp-main-img', this, '{{ 'merch-1Y0A0877.jpg' | asset_url }}')">
        <img src="{{ 'merch-1Y0A0877.jpg' | asset_url }}" alt="">
      </div>
      <div class="mpdp-thumb" onclick="mpdpSwap('fp-main-img', this, '{{ 'merch-1Y0A0910.jpg' | asset_url }}')">
        <img src="{{ 'merch-1Y0A0910.jpg' | asset_url }}" alt="">
      </div>
      <div class="mpdp-thumb" onclick="mpdpSwap('fp-main-img', this, '{{ 'merch-1Y0A0926.jpg' | asset_url }}')">
        <img src="{{ 'merch-1Y0A0926.jpg' | asset_url }}" alt="">
      </div>
      <div class="mpdp-thumb" onclick="mpdpSwap('fp-main-img', this, '{{ 'merch-1Y0A9997.jpg' | asset_url }}')">
        <img src="{{ 'merch-1Y0A9997.jpg' | asset_url }}" alt="">
      </div>
      <div class="mpdp-thumb" onclick="mpdpSwap('fp-main-img', this, '{{ 'merch-1Y0A0820.jpg' | asset_url }}')">
        <img src="{{ 'merch-1Y0A0820.jpg' | asset_url }}" alt="">
      </div>
    </div>
  </div>

  <!-- Purchase panel -->
  <div class="mpdp-panel">
    <div class="mpdp-breadcrumb"><a href="/pages/essentials1">essentials</a> / tee future proof</div>

    <!-- Green banner -->
    <div class="mpdp-banner">stay future proof.</div>

    <h1 class="mpdp-title">day–guard tee future proof</h1>
    <div class="mpdp-price">$34.99</div>

    <!-- Color swatches -->
    <div class="mpdp-swatches-label">color</div>
    <div class="mpdp-swatches">
      <div class="mpdp-swatch active" style="background:#204c3e;" title="Forest Green" onclick="mpdpSelectSwatch(this)"></div>
      <div class="mpdp-swatch" style="background:#9aaca0;" title="Sage" onclick="mpdpSelectSwatch(this)"></div>
    </div>

    <!-- Sizes -->
    <div class="mpdp-sizes-label">size</div>
    <div class="mpdp-sizes">
      <button class="mpdp-size-btn active" onclick="mpdpSelectSize(this)">S</button>
      <button class="mpdp-size-btn" onclick="mpdpSelectSize(this)">M</button>
      <button class="mpdp-size-btn" onclick="mpdpSelectSize(this)">L</button>
    </div>

    <!-- Qty + ATC -->
    <div class="mpdp-atc-row">
      <div class="mpdp-qty">
        <button class="mpdp-qty-btn" onclick="mpdpQtyChange('fp-qty-val', -1)">−</button>
        <span class="mpdp-qty-val" id="fp-qty-val">1</span>
        <button class="mpdp-qty-btn" onclick="mpdpQtyChange('fp-qty-val', 1)">+</button>
      </div>
      <button class="mpdp-atc-btn">add to cart</button>
    </div>
    <p class="mpdp-checkout-note">Tax included. Shipping calculated at checkout.</p>

    <!-- Accordions -->
    <div class="mpdp-accord">
      <div class="mpdp-accord-item" id="mpdp-fp-materials">
        <button class="mpdp-accord-trigger" onclick="mpdpToggleAccord('mpdp-fp-materials')">
          <span>materials</span>
          <span class="mpdp-accord-icon">+</span>
        </button>
        <div class="mpdp-accord-body">
          <div class="mpdp-accord-inner">
            <ul>
              <li>100% heavyweight organic cotton</li>
              <li>320 GSM — substantial and structured</li>
              <li>Enzyme-washed for softness</li>
              <li>Ribbed crew neck</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="mpdp-accord-item" id="mpdp-fp-sizeguide">
        <button class="mpdp-accord-trigger" onclick="mpdpToggleAccord('mpdp-fp-sizeguide')">
          <span>size guide</span>
          <span class="mpdp-accord-icon">+</span>
        </button>
        <div class="mpdp-accord-body">
          <div class="mpdp-accord-inner">
            <ul>
              <li>S — chest 36–38", length 27"</li>
              <li>M — chest 39–41", length 28"</li>
              <li>L — chest 42–44", length 29"</li>
            </ul>
            <p>Fits true to size. Model is 6'1" wearing size M.</p>
          </div>
        </div>
      </div>
      <div class="mpdp-accord-item" id="mpdp-fp-shipping">
        <button class="mpdp-accord-trigger" onclick="mpdpToggleAccord('mpdp-fp-shipping')">
          <span>shipping &amp; returns</span>
          <span class="mpdp-accord-icon">+</span>
        </button>
        <div class="mpdp-accord-body">
          <div class="mpdp-accord-inner">
            <p>Ships within 2–4 business days. Free returns within 30 days.</p>
          </div>
        </div>
      </div>
    </div>

  </div>

</section>

<!-- Recommendations -->
<section class="merch-recs">
  <div class="merch-recs-header">
    <span class="merch-recs-title">recommendations</span>
    <a class="merch-recs-link" href="/pages/essentials1">discover more →</a>
  </div>
  <div class="merch-recs-grid">
    <a class="merch-rec-card" href="/pages/merch-mosaic">
      <div class="merch-rec-img"><img src="{{ 'merch-1Y0A9888.jpg' | asset_url }}" alt="mosaic tee"></div>
      <div class="merch-rec-name">day–guard tee mosaic</div>
      <div class="merch-rec-price">$34.99</div>
    </a>
    <a class="merch-rec-card" href="/pages/merch-wine-opener">
      <div class="merch-rec-img"><img src="{{ 'merch-1Y0A0361.jpg' | asset_url }}" alt="wine bottle opener"></div>
      <div class="merch-rec-name">day–guard wine bottle opener</div>
      <div class="merch-rec-price">$13.00</div>
    </a>
    <a class="merch-rec-card" href="/pages/merch-ice-cube">
      <div class="merch-rec-img"><img src="{{ 'merch-1Y0A0682.jpg' | asset_url }}" alt="wine ice cube"></div>
      <div class="merch-rec-name">day–guard wine ice cube</div>
      <div class="merch-rec-price">$19.00</div>
    </a>
  </div>
</section>

{% stylesheet %}
.merch-pdp { display: grid; grid-template-columns: 1fr 447px; gap: 60px; max-width: 1302px; margin: 0 auto; padding: 60px 60px 80px; background: #f4f1ec; min-height: 80vh; align-items: start; }
.mpdp-gallery { display: flex; flex-direction: column; gap: 12px; }
.mpdp-gallery-main { width: 100%; aspect-ratio: 1/1; border-radius: 16px; overflow: hidden; background: #e8e5e0; }
.mpdp-main-img { width: 100%; height: 100%; object-fit: cover; transition: opacity 0.25s; }
.mpdp-thumbs { display: flex; gap: 10px; flex-wrap: wrap; }
.mpdp-thumb { width: 72px; height: 72px; border-radius: 8px; overflow: hidden; cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s; background: #e8e5e0; }
.mpdp-thumb.active { border-color: #204c3e; }
.mpdp-thumb img { width: 100%; height: 100%; object-fit: cover; }
.mpdp-panel { padding-top: 8px; }
.mpdp-breadcrumb { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 13px; color: #888; margin-bottom: 20px; }
.mpdp-breadcrumb a { color: #888; text-decoration: none; }
.mpdp-breadcrumb a:hover { color: #204c3e; }
.mpdp-banner { background: #204c3e; color: #fff; font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 14px; font-weight: 500; letter-spacing: 0.5px; padding: 10px 16px; border-radius: 6px; margin-bottom: 20px; text-align: center; }
.mpdp-title { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 45px; font-weight: 700; letter-spacing: -1.8px; color: #1d1d1b; line-height: 1.05; margin: 0 0 16px; }
.mpdp-price { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 22px; font-weight: 500; color: #1d1d1b; letter-spacing: -0.5px; margin-bottom: 20px; }
.mpdp-swatches-label, .mpdp-sizes-label { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 13px; font-weight: 600; color: #1d1d1b; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
.mpdp-swatches { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
.mpdp-swatch { width: 28px; height: 28px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; }
.mpdp-swatch.active { outline: 2px solid #204c3e; outline-offset: 2px; }
.mpdp-sizes { display: flex; gap: 8px; margin-bottom: 28px; flex-wrap: wrap; }
.mpdp-size-btn { width: 44px; height: 36px; border: 1.5px solid #ccc; border-radius: 4px; background: #fff; font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 13px; font-weight: 500; color: #1d1d1b; cursor: pointer; transition: border-color 0.2s, background 0.2s; }
.mpdp-size-btn.active, .mpdp-size-btn:hover { border-color: #204c3e; background: #204c3e; color: #fff; }
.mpdp-atc-row { display: flex; gap: 12px; align-items: center; margin-bottom: 10px; }
.mpdp-qty { display: flex; align-items: center; border: 1.5px solid #ccc; border-radius: 4px; overflow: hidden; height: 37px; min-width: 117px; }
.mpdp-qty-btn { width: 36px; height: 37px; background: none; border: none; font-size: 20px; color: #1d1d1b; cursor: pointer; display: flex; align-items: center; justify-content: center; }
.mpdp-qty-btn:hover { background: #f0ede8; }
.mpdp-qty-val { flex: 1; text-align: center; font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 16px; font-weight: 500; color: #1d1d1b; user-select: none; }
.mpdp-atc-btn { flex: 1; height: 37px; max-width: 215px; background: #fb9918; color: #fff; border: none; border-radius: 3px; font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 15px; font-weight: 500; cursor: pointer; transition: background 0.2s; }
.mpdp-atc-btn:hover { background: #e8860f; }
.mpdp-checkout-note { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 12px; color: #888; margin: 6px 0 24px; }
.mpdp-accord { border-top: 1px solid rgba(0,0,0,0.1); }
.mpdp-accord-item { border-bottom: 1px solid rgba(0,0,0,0.1); }
.mpdp-accord-trigger { display: flex; justify-content: space-between; align-items: center; width: 100%; background: none; border: none; padding: 16px 0; cursor: pointer; font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 15px; font-weight: 500; color: #1d1d1b; text-align: left; }
.mpdp-accord-icon { font-size: 20px; font-weight: 300; color: #888; transition: transform 0.25s; line-height: 1; }
.mpdp-accord-item.open .mpdp-accord-icon { transform: rotate(45deg); }
.mpdp-accord-body { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
.mpdp-accord-item.open .mpdp-accord-body { max-height: 300px; }
.mpdp-accord-inner { padding-bottom: 16px; }
.mpdp-accord-inner p, .mpdp-accord-inner li { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 14px; color: #555; line-height: 1.6; }
.mpdp-accord-inner ul { padding-left: 20px; margin: 0; }
.merch-recs { background: #f4f1ec; padding: 60px 60px 80px; max-width: 1302px; margin: 0 auto; }
.merch-recs-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 28px; }
.merch-recs-title { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 28px; font-weight: 700; letter-spacing: -1px; color: #1d1d1b; }
.merch-recs-link { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 14px; color: #204c3e; text-decoration: none; }
.merch-recs-link:hover { text-decoration: underline; }
.merch-recs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.merch-rec-card { display: block; text-decoration: none; color: inherit; }
.merch-rec-img { aspect-ratio: 1/1; border-radius: 13px; overflow: hidden; background: #e8e5e0; margin-bottom: 12px; }
.merch-rec-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.35s ease; }
.merch-rec-card:hover .merch-rec-img img { transform: scale(1.03); }
.merch-rec-name { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 16px; font-weight: 500; color: #1d1d1b; margin-bottom: 4px; }
.merch-rec-price { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 14px; color: #555; }
@media (max-width: 900px) {
  .merch-pdp { grid-template-columns: 1fr; padding: 30px 20px 60px; gap: 32px; }
  .merch-recs { padding: 40px 20px 60px; }
  .merch-recs-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .mpdp-title { font-size: 30px; letter-spacing: -1px; }
  .merch-recs-grid { grid-template-columns: 1fr; }
}
{% endstylesheet %}

{% javascript %}
function mpdpSwap(imgId, thumb, src) {
  document.getElementById(imgId).src = src;
  thumb.closest('.mpdp-thumbs').querySelectorAll('.mpdp-thumb').forEach(function(t) { t.classList.remove('active'); });
  thumb.classList.add('active');
}
function mpdpQtyChange(valId, delta) {
  var el = document.getElementById(valId);
  var v = parseInt(el.textContent) + delta;
  if (v < 1) v = 1;
  el.textContent = v;
}
function mpdpToggleAccord(id) {
  document.getElementById(id).classList.toggle('open');
}
function mpdpSelectSize(btn) {
  btn.closest('.mpdp-sizes').querySelectorAll('.mpdp-size-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
}
function mpdpSelectSwatch(el) {
  el.closest('.mpdp-swatches').querySelectorAll('.mpdp-swatch').forEach(function(s) { s.classList.remove('active'); });
  el.classList.add('active');
}
{% endjavascript %}

