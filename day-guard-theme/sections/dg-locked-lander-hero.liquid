.ll-subscribe-btn:hover { background: #e8860f; }
{% endstylesheet %}

{% javascript %}
function llSelect(id, e) {
  if (e) e.preventDefault();
  document.querySelectorAll('.ll-option').forEach(function(o) {
    o.classList.remove('ll-option--active');
  });
  document.getElementById(id).classList.add('ll-option--active');
  // Update sticky price
  var prices = { 'll-opt-3': '$69', 'll-opt-2': '$55', 'll-opt-1': '$29' };
  var el = document.getElementById('sticky-price-label');
  if (el) el.textContent = (prices[id] || '$29') + ' · subscribe & save';
}
{% endjavascript %}

