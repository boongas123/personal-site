    <!-- RIGHT PANEL: lifestyle photo -->
    <div class="footer-right">
      <img class="footer-girl-img"
           src="{{ 'footer-lifestyle.png' | asset_url }}"
           alt="day–guard lifestyle">
      <div class="footer-right-overlay">
        <img class="footer-dg-logo" src="{{ 'DG_Horizontal_White.png' | asset_url }}" alt="day–guard">
        <span class="footer-tagline">social tonight. healthy tomorrow.</span>
      </div>
