{%- assign dg_url = '/products/day-guard-pack-of-10' -%}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }}{% if page_title != shop.name %} — {{ shop.name }}{% endif %}</title>

  {%- comment -%} Google Fonts {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Hedvig+Letters+Serif:opsz@12..24&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,700&display=swap" rel="stylesheet">

  {%- comment -%} Sofia Pro via Adobe Fonts / Typekit {%- endcomment -%}
  <link rel="stylesheet" href="https://use.typekit.net/placeholder.css" onerror="void(0)">

  {%- comment -%} Day-Guard combined stylesheet {%- endcomment -%}
  {{ 'dayguard.css' | asset_url | stylesheet_tag }}

  {%- comment -%} Shopify required hook {%- endcomment -%}
  {{ content_for_header }}
</head>
<body>

  {%- comment -%} Cart overlay + full drawer (PDP has items; homepage has empty state) {%- endcomment -%}
  <div class="cart-overlay" id="cart-overlay"></div>
  <div class="cart-drawer" id="cart-drawer">
    <div class="cart-drawer-header">
      <span class="cart-drawer-title">your cart</span>
      <button class="cart-drawer-close" id="cart-close" aria-label="Close cart">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="cart-drawer-body" id="cart-drawer-body">
      {%- comment -%} Empty state {%- endcomment -%}
      <div class="cart-empty" id="cart-empty">
        <div class="cart-empty-icon">🛍</div>
        <p>your cart is empty</p>
        <a href="/products/day-guard-pack-of-10" class="cart-shop-link">shop now →</a>
      </div>
      <div id="cart-items-wrap" style="display:none"></div>
    </div>
    {%- comment -%} Cart footer — hidden until items present {%- endcomment -%}
    <div class="cart-footer-section" id="cart-footer" style="display:none">
      <div class="cart-subtotal">
        <span>subtotal</span>
        <span class="cart-subtotal-price" id="cart-subtotal">$75.00</span>
      </div>
      <p class="cart-note">tax included · shipping calculated at checkout</p>
      <a href="{{ routes.checkout_url }}" class="cart-checkout-btn">checkout →</a>
    </div>
  </div>

  {%- comment -%} Pillar modal overlay (shared across homepage + PDP) {%- endcomment -%}
  <div class="pillar-modal-overlay" id="pillarModal">
    <div class="pillar-modal">
      <div class="pillar-modal-left">
        <img class="pillar-modal-bg" id="pillarModalBg" src="" alt="">
        <div class="pillar-modal-left-gradient"></div>
        <span class="pillar-modal-left-label" id="pillarModalLabel"></span>
      </div>
      <div class="pillar-modal-right">
        <button class="pillar-modal-close" id="pillarModalClose" aria-label="Close">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 1L12 12M12 1L1 12" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </button>
        <p class="pillar-modal-title" id="pillarModalTitle"></p>
        <p class="pillar-modal-desc" id="pillarModalDesc"></p>
        <ul class="pillar-modal-ing-list" id="pillarModalIngList"></ul>
      </div>
    </div>
  </div>

  {%- comment -%} ════════════════════════════════
       NAV
       Homepage: transparent → beige on scroll (id="site-nav")
       PDP: always solid — class "nav--solid" set by section
  ════════════════════════════════ {%- endcomment -%}
  {%- if template.name == 'product' -%}
    {%- assign nav_id = 'nav' -%}
    {%- assign nav_extra_class = 'nav--solid' -%}
  {%- elsif template.name == 'page' and page.handle == 'essentials1' or template.name == 'page' and page.handle == 'merch-wine-opener' or template.name == 'page' and page.handle == 'merch-ice-cube' or template.name == 'page' and page.handle == 'merch-mosaic' or template.name == 'page' and page.handle == 'merch-future-proof' or template.name == 'page' and page.handle == 'science1' or template.name == 'page' and page.handle == 'lockedlander' -%}
    {%- assign nav_id = 'nav' -%}
    {%- assign nav_extra_class = 'nav--solid' -%}
  {%- else -%}
    {%- assign nav_id = 'site-nav' -%}
    {%- assign nav_extra_class = '' -%}
  {%- endif -%}
  <nav class="nav {{ nav_extra_class }}" id="{{ nav_id }}">
    <a href="{{ routes.root_url }}" class="nav-logo" aria-label="day–guard home">
      <img class="nav-logo-light" src="{{ 'DG_Horizontal_White.png' | asset_url }}" alt="day–guard">
      <img class="nav-logo-dark"  src="{{ 'DG_Horizontal_Black.png' | asset_url }}" alt="day–guard">
      <span class="nav-logo-fallback" style="display:none">day–guard</span>
    </a>
    <ul class="nav-links">
      <li class="nav-item has-dropdown">
        <a href="/products/day-guard-pack-of-10" class="has-arrow">shop</a>
        <div class="nav-dropdown">
          <a href="/products/day-guard-pack-of-10">pre-alcohol vitamin jelly</a>
          <a href="#">every day-guard</a>
          <a href="#">bulk order</a>
          <a href="/pages/essentials1">merch</a>
          <a href="/pages/lockedlander">locked lander</a>
        </div>
      </li>
      <li><a href="/pages/science1">science</a></li>
      <li class="nav-item has-dropdown">
        <a href="#" class="has-arrow">learn</a>
        <div class="nav-dropdown">
          <a href="#">about us</a>
          <a href="#">blog</a>
        </div>
      </li>
      <li class="nav-item has-dropdown">
        <a href="/pages/help" class="has-arrow">help</a>
        <div class="nav-dropdown">
          <a href="/pages/help">Help Center</a>
          <a href="/pages/faq">FAQs</a>
          <a href="/pages/contact">Contact Us</a>
        </div>
      </li>
    </ul>
    <button class="nav-cart" id="cart-trigger" aria-label="Open cart">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      <span class="nav-cart-count" id="cart-count" style="display:none">0</span>
    </button>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  {%- comment -%} Mobile slide-in menu {%- endcomment -%}
  <div class="mobile-menu-overlay" id="mobile-menu-overlay"></div>
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-top">
      <button class="mobile-menu-close" id="mobile-menu-close" aria-label="Close menu">&times;</button>
    </div>
    <nav class="mobile-menu-nav">
      <a href="/products/day-guard-pack-of-10">shop</a>
      <a href="/pages/science">science</a>
      <a href="#">learn</a>
      <a href="/pages/help">help</a>
    </nav>
  </div>

  {%- comment -%} ════ PAGE CONTENT ════ {%- endcomment -%}
  {{ content_for_layout }}

  {%- comment -%} ════════════════════════════════
       FOOTER — shared across all pages
  ════════════════════════════════ {%- endcomment -%}
  <footer class="footer" id="footer">

    <!-- LEFT PANEL: dark green -->
    <div class="footer-left">
      <div class="footer-left-top">
        <p class="footer-signup-h">Join for 15% off your first order.</p>
        <div class="footer-toggles">
          <button class="ft-btn active" id="ft-email">email</button>
          <button class="ft-btn" id="ft-sms">sms</button>
        </div>
        <div class="footer-form">
          <input class="footer-input" id="ft-input" type="email" placeholder="enter your email.">
          <button class="footer-submit" id="ft-submit" type="button" aria-label="Subscribe">→</button>
        </div>
        <p class="ft-msg" id="ft-msg"></p>
        <p class="footer-disclaimer">*by completing this form you are signing up to receive our marketing and can unsubscribe at any time.</p>
      </div>

      <div class="footer-nav-grid">
        <div class="footer-nav-col">
          <p class="footer-nav-h">Shop</p>
          <ul class="footer-nav-links">
            <li><a href="/products/day-guard-pack-of-10">Pre-Alcohol Vitamin Jelly</a></li>
            <li><a href="#">Every Day-Guard</a></li>
            <li><a href="#">Bulk Order</a></li>
            <li><a href="#">Merch</a></li>
          </ul>
        </div>
        <div class="footer-nav-col">
          <p class="footer-nav-h">Learn</p>
          <ul class="footer-nav-links">
            <li><a href="#">About Us</a></li>
            <li><a href="#">Blog</a></li>
            <li><a href="/#ingredients">Science</a></li>
            <li><a href="#">Careers</a></li>
          </ul>
        </div>
        <div class="footer-nav-col">
          <p class="footer-nav-h">Legal</p>
          <ul class="footer-nav-links">
            <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
            <li><a href="/pages/terms-conditions">Terms &amp; Conditions</a></li>
            <li><a href="/pages/accessibility">Accessibility</a></li>
          </ul>
        </div>
        <div class="footer-nav-col">
          <p class="footer-nav-h">Support</p>
          <ul class="footer-nav-links">
            <li><a href="/pages/help">Help Center</a></li>
            <li><a href="/pages/faq">FAQs</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
          </ul>
        </div>
      </div>

