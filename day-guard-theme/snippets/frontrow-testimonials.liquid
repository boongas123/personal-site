{% doc %}
  Renders the FrontrowMD Clinicians' Choice widget for the day-guard product.
  Displays an iframe widget with clinician testimonials from FrontrowMD.
  Only renders on product pages.
{% enddoc %}

<section class="fr-testimonials">
  {% if request.path contains '/products/' %}
    <script async type="text/javascript" src="https://app.thefrontrowhealth.com/api/widgets/script?presentation_type=qual&product_id=3813"></script>
    <iframe id="frontrow-testimonials" class="iframe-frontrow-testimonials" frameborder="0" src="https://app.thefrontrowhealth.com/api/widgets?presentation_type=qual&product_id=3813"></iframe>
  {% endif %}
  <style>iframe.iframe-frontrow-testimonials { width: 100%; } iframe.iframe-modal-testimonials { z-index: 99999998; }</style>
</section>
